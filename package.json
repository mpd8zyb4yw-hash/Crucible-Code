{
  "name": "crucible",
  "main": "electron.cjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tsx server.ts\" \"npx vite\"",
    "server": "tsx server.ts",
    "smoke": "tsx src/CrucibleEngine/smoke-benchmarks.ts",
    "smoke:code": "tsx src/CrucibleEngine/coding-benchmarks.ts",
    "smoke:code:offline": "CRUCIBLE_OFFLINE=strict tsx src/CrucibleEngine/coding-benchmarks.ts",
    "synth:prove": "tsx src/CrucibleEngine/synth/synth-prove.ts",
    "bench:ocb": "tsx src/CrucibleEngine/synth/ocb-runner.ts",
    "synth:taxonomy": "tsx src/CrucibleEngine/synth/synth-taxonomy.ts",
    "census": "tsx src/CrucibleEngine/synth/coverage-census.ts",
    "validate:batch": "tsx src/CrucibleEngine/synth/validate-batch.ts",
    "prove:all": "npm run harden:bench && npm run fuzz:bench && npm run stakes:bench && npm run contract:bench && npm run lintgate:bench && npm run repair:bench && tsx src/CrucibleEngine/synth/prove-all.ts",
    "fuzz:bench": "tsx src/CrucibleEngine/agent/__fuzz_bench.ts",
    "harden:bench": "tsx src/CrucibleEngine/agent/__localHardenCheck_bench.ts",
    "contract:bench": "tsx src/CrucibleEngine/synth/__contractGate_bench.ts",
    "lintgate:bench": "tsx src/CrucibleEngine/synth/__lintGate_bench.ts",
    "repair:bench": "tsx src/CrucibleEngine/synth/__repairProposers_bench.ts",
    "generate:skills": "tsx src/CrucibleEngine/synth/generate.ts",
    "diag": "curl -s http://localhost:3001/api/diag | python3 -m json.tool",
    "build": "tsc -b && vite build",
    "bundle:server": "node scripts/bundle-server.mjs",
    "dist": "npm run bundle:server && vite build && electron-builder",
    "dist:mac": "npm run bundle:server && vite build && electron-builder --mac",
    "dist:win": "npm run bundle:server && vite build && electron-builder --win",
    "dist:linux": "npm run bundle:server && vite build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "wait-on --timeout 30000 http://localhost:5173 http://localhost:3001 && sleep 3 && npx electron electron.cjs",
    "predev": "pkill -f \"tsx server\" || true; pkill -f \"vite\" || true; lsof -ti:5173 | xargs kill -9 2>/dev/null || true; lsof -ti:3001 | xargs kill -9 2>/dev/null || true; sleep 1",
    "synth:universal": "tsx src/CrucibleEngine/synth/universal-prove.ts",
    "synth:enum": "tsx src/CrucibleEngine/synth/enumerative-prove.ts",
    "synth:fm-bench": "tsx src/CrucibleEngine/synth/fm-bench.ts",
    "research:bench": "tsx src/CrucibleEngine/research/researchBenchmark.ts",
    "ambiguity:bench": "tsx src/CrucibleEngine/ambiguity-bench.ts",
    "stakes:bench": "tsx src/CrucibleEngine/agent/stakesRouter-bench.ts",
    "answer:bench": "tsx src/CrucibleEngine/answer/__answer_bench.ts",
    "vgr:bench": "tsx src/CrucibleEngine/reasoning/__vgr_bench.ts",
    "vgr:iterate": "tsx src/CrucibleEngine/reasoning/__iterate_bench.ts",
    "convo:coherence": "tsx __convo_coherence_bench.ts",
    "bench:all": "tsx src/CrucibleEngine/__bench_all.ts"
  },
  "build": {
    "appId": "com.crucible.local",
    "productName": "Crucible",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "extraMetadata": {
      "main": "electron.cjs"
    },
    "files": [
      "electron.cjs",
      "server-dist/**/*",
      "app/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/@xenova/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/sharp/**/*",
      "**/*.node"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mpd8zyb4yw-hash",
        "repo": "Crucible"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.5",
    "@types/compression": "^1.8.1",
    "@types/pg": "^8.20.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "fast-check": "^4.8.0",
    "groq-sdk": "^1.2.1",
    "node-llama-cpp": "^3.19.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright-core": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
