[
  {
    "id": "parse-iso-duration",
    "filename": "parseIsoDuration",
    "summary": "parseIsoDuration converts an ISO-8601 duration like PT1H30M or P1DT2H to milliseconds; invalid input returns NaN.",
    "defaultPath": "src/parseIsoDuration.ts",
    "exports": [
      "parseIsoDuration"
    ],
    "patterns": [
      {
        "re": "\\bparseIsoDuration\\b",
        "weight": 0.6
      },
      {
        "re": "iso.*duration|duration.*iso.*8601",
        "weight": 0.3
      }
    ],
    "impl": "export function parseIsoDuration(s: string): number {\n  const m = s.match(/^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+(?:\\.\\d+)?)S)?)?$/)\n  if (!m) return NaN\n  const [,Y,Mo,D,H,Mi,S] = m\n  return ((+(Y??0)*365 + +(Mo??0)*30 + +(D??0))*24*3600 + +(H??0)*3600 + +(Mi??0)*60 + +(S??0)) * 1000\n}",
    "tests": [
      {
        "desc": "one hour",
        "call": "parseIsoDuration(\"PT1H\")",
        "want": "3600000"
      },
      {
        "desc": "90 min",
        "call": "parseIsoDuration(\"PT1H30M\")",
        "want": "5400000"
      },
      {
        "desc": "1 day",
        "call": "parseIsoDuration(\"P1D\")",
        "want": "86400000"
      },
      {
        "desc": "1 day 2 hours",
        "call": "parseIsoDuration(\"P1DT2H\")",
        "want": "93600000"
      },
      {
        "desc": "30 seconds",
        "call": "parseIsoDuration(\"PT30S\")",
        "want": "30000"
      },
      {
        "desc": "invalid",
        "call": "Number.isNaN(parseIsoDuration(\"notaduration\"))",
        "want": "true"
      }
    ]
  },
  {
    "id": "format-duration",
    "filename": "formatDuration",
    "summary": "formatDuration humanizes milliseconds to \"1h 30m\" style using up to two largest non-zero units; 0ms returns \"0s\".",
    "defaultPath": "src/formatDuration.ts",
    "exports": [
      "formatDuration"
    ],
    "patterns": [
      {
        "re": "\\bformatDuration\\b",
        "weight": 0.6
      },
      {
        "re": "format.*duration|humanize.*ms|duration.*human",
        "weight": 0.3
      }
    ],
    "impl": "export function formatDuration(ms: number): string {\n  if (ms === 0) return '0s'\n  const units: [string, number][] = [['d',86400000],['h',3600000],['m',60000],['s',1000]]\n  const parts: string[] = []\n  let rem = ms\n  for (const [label, factor] of units) {\n    const v = Math.floor(rem / factor)\n    if (v) { parts.push(v + label); rem -= v * factor }\n    if (parts.length === 2) break\n  }\n  return parts.join(' ') || '<1s'\n}",
    "tests": [
      {
        "desc": "zero",
        "call": "formatDuration(0)",
        "want": "\"0s\""
      },
      {
        "desc": "90 min",
        "call": "formatDuration(5400000)",
        "want": "\"1h 30m\""
      },
      {
        "desc": "45 sec",
        "call": "formatDuration(45000)",
        "want": "\"45s\""
      },
      {
        "desc": "2 days 3 hours",
        "call": "formatDuration(2*86400000+3*3600000)",
        "want": "\"2d 3h\""
      },
      {
        "desc": "exact hour",
        "call": "formatDuration(3600000)",
        "want": "\"1h\""
      }
    ]
  },
  {
    "id": "iso-week-number",
    "filename": "isoWeekNumber",
    "summary": "isoWeekNumber returns the ISO-8601 week number (1 to 53) for a Date using UTC.",
    "defaultPath": "src/isoWeekNumber.ts",
    "exports": [
      "isoWeekNumber"
    ],
    "patterns": [
      {
        "re": "\\bisoWeekNumber\\b",
        "weight": 0.6
      },
      {
        "re": "iso.*week|week.*number.*iso",
        "weight": 0.3
      }
    ],
    "impl": "export function isoWeekNumber(date: Date): number {\n  const d = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate()))\n  d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7))\n  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1))\n  return Math.ceil((((d.getTime() - yearStart.getTime()) / 86400000) + 1) / 7)\n}",
    "tests": [
      {
        "desc": "2024-01-01 is week 1",
        "call": "isoWeekNumber(new Date(\"2024-01-01T00:00:00Z\"))",
        "want": "1"
      },
      {
        "desc": "2024-01-07 is week 1",
        "call": "isoWeekNumber(new Date(\"2024-01-07T00:00:00Z\"))",
        "want": "1"
      },
      {
        "desc": "2024-01-08 is week 2",
        "call": "isoWeekNumber(new Date(\"2024-01-08T00:00:00Z\"))",
        "want": "2"
      },
      {
        "desc": "2023-12-31 is week 52",
        "call": "isoWeekNumber(new Date(\"2023-12-31T00:00:00Z\"))",
        "want": "52"
      },
      {
        "desc": "mid year",
        "call": "isoWeekNumber(new Date(\"2024-06-15T00:00:00Z\"))",
        "want": "24"
      }
    ]
  },
  {
    "id": "business-days-between",
    "filename": "businessDaysBetween",
    "summary": "businessDaysBetween counts Mon-Fri days strictly between date a and inclusive of date b (a <= b), in UTC.",
    "defaultPath": "src/businessDaysBetween.ts",
    "exports": [
      "businessDaysBetween"
    ],
    "patterns": [
      {
        "re": "\\bbusinessDaysBetween\\b",
        "weight": 0.6
      },
      {
        "re": "business days|working days",
        "weight": 0.3
      }
    ],
    "impl": "export function businessDaysBetween(a: Date, b: Date): number {\n  let count = 0\n  const cur = new Date(Date.UTC(a.getUTCFullYear(), a.getUTCMonth(), a.getUTCDate() + 1))\n  const end = new Date(Date.UTC(b.getUTCFullYear(), b.getUTCMonth(), b.getUTCDate()))\n  while (cur <= end) {\n    const dow = cur.getUTCDay()\n    if (dow !== 0 && dow !== 6) count++\n    cur.setUTCDate(cur.getUTCDate() + 1)\n  }\n  return count\n}",
    "tests": [
      {
        "desc": "Mon to Fri",
        "call": "businessDaysBetween(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-05T00:00:00Z\"))",
        "want": "4"
      },
      {
        "desc": "same day",
        "call": "businessDaysBetween(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-01T00:00:00Z\"))",
        "want": "0"
      },
      {
        "desc": "skips weekend",
        "call": "businessDaysBetween(new Date(\"2024-01-05T00:00:00Z\"),new Date(\"2024-01-08T00:00:00Z\"))",
        "want": "1"
      },
      {
        "desc": "full week",
        "call": "businessDaysBetween(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-08T00:00:00Z\"))",
        "want": "5"
      }
    ]
  },
  {
    "id": "add-business-days",
    "filename": "addBusinessDays",
    "summary": "addBusinessDays adds n business days (Mon-Fri) to a Date in UTC, returning a new Date.",
    "defaultPath": "src/addBusinessDays.ts",
    "exports": [
      "addBusinessDays"
    ],
    "patterns": [
      {
        "re": "\\baddBusinessDays\\b",
        "weight": 0.6
      },
      {
        "re": "add.*business.*days?|business.*days?.*add",
        "weight": 0.3
      }
    ],
    "impl": "export function addBusinessDays(date: Date, n: number): Date {\n  const d = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate()))\n  let remaining = n\n  while (remaining > 0) {\n    d.setUTCDate(d.getUTCDate() + 1)\n    const dow = d.getUTCDay()\n    if (dow !== 0 && dow !== 6) remaining--\n  }\n  return d\n}",
    "tests": [
      {
        "desc": "add 5 from Mon",
        "call": "addBusinessDays(new Date(\"2024-01-01T00:00:00Z\"),5).toISOString().slice(0,10)",
        "want": "\"2024-01-08\""
      },
      {
        "desc": "add 1 before weekend",
        "call": "addBusinessDays(new Date(\"2024-01-05T00:00:00Z\"),1).toISOString().slice(0,10)",
        "want": "\"2024-01-08\""
      },
      {
        "desc": "add 0",
        "call": "addBusinessDays(new Date(\"2024-01-01T00:00:00Z\"),0).toISOString().slice(0,10)",
        "want": "\"2024-01-01\""
      },
      {
        "desc": "cross weekend",
        "call": "addBusinessDays(new Date(\"2024-01-04T00:00:00Z\"),2).toISOString().slice(0,10)",
        "want": "\"2024-01-08\""
      }
    ]
  },
  {
    "id": "quarter-of",
    "filename": "quarterOf",
    "summary": "quarterOf returns the calendar quarter (1 to 4) of a Date using UTC month.",
    "defaultPath": "src/quarterOf.ts",
    "exports": [
      "quarterOf"
    ],
    "patterns": [
      {
        "re": "\\bquarterOf\\b",
        "weight": 0.6
      },
      {
        "re": "calendar quarter|quarter.*date",
        "weight": 0.3
      }
    ],
    "impl": "export function quarterOf(date: Date): number { return Math.ceil((date.getUTCMonth() + 1) / 3) }",
    "tests": [
      {
        "desc": "Q1 Jan",
        "call": "quarterOf(new Date(\"2024-01-15T00:00:00Z\"))",
        "want": "1"
      },
      {
        "desc": "Q1 Mar",
        "call": "quarterOf(new Date(\"2024-03-31T00:00:00Z\"))",
        "want": "1"
      },
      {
        "desc": "Q2 Apr",
        "call": "quarterOf(new Date(\"2024-04-01T00:00:00Z\"))",
        "want": "2"
      },
      {
        "desc": "Q3 Aug",
        "call": "quarterOf(new Date(\"2024-08-01T00:00:00Z\"))",
        "want": "3"
      },
      {
        "desc": "Q4 Dec",
        "call": "quarterOf(new Date(\"2024-12-31T00:00:00Z\"))",
        "want": "4"
      }
    ]
  },
  {
    "id": "date-range-days",
    "filename": "dateRangeDays",
    "summary": "dateRangeDays returns an inclusive list of YYYY-MM-DD UTC date strings from date a to date b.",
    "defaultPath": "src/dateRangeDays.ts",
    "exports": [
      "dateRangeDays"
    ],
    "patterns": [
      {
        "re": "\\bdateRangeDays\\b",
        "weight": 0.6
      },
      {
        "re": "date.*range.*list|list.*dates.*between",
        "weight": 0.3
      }
    ],
    "impl": "export function dateRangeDays(a: Date, b: Date): string[] {\n  const out: string[] = []\n  const cur = new Date(Date.UTC(a.getUTCFullYear(), a.getUTCMonth(), a.getUTCDate()))\n  const end = new Date(Date.UTC(b.getUTCFullYear(), b.getUTCMonth(), b.getUTCDate()))\n  while (cur <= end) { out.push(cur.toISOString().slice(0,10)); cur.setUTCDate(cur.getUTCDate()+1) }\n  return out\n}",
    "tests": [
      {
        "desc": "three days",
        "call": "dateRangeDays(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-03T00:00:00Z\"))",
        "want": "[\"2024-01-01\",\"2024-01-02\",\"2024-01-03\"]"
      },
      {
        "desc": "same day",
        "call": "dateRangeDays(new Date(\"2024-06-15T00:00:00Z\"),new Date(\"2024-06-15T00:00:00Z\"))",
        "want": "[\"2024-06-15\"]"
      },
      {
        "desc": "length",
        "call": "dateRangeDays(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-07T00:00:00Z\")).length",
        "want": "7"
      }
    ]
  },
  {
    "id": "humanize-relative-time",
    "filename": "humanizeRelativeTime",
    "summary": "humanizeRelativeTime produces phrases like \"in 3 days\" or \"2 hours ago\" from two Dates using the largest unit.",
    "defaultPath": "src/humanizeRelativeTime.ts",
    "exports": [
      "humanizeRelativeTime"
    ],
    "patterns": [
      {
        "re": "\\bhumanizeRelativeTime\\b",
        "weight": 0.6
      },
      {
        "re": "relative.*time|time.*ago|humanize.*time",
        "weight": 0.3
      }
    ],
    "impl": "export function humanizeRelativeTime(from: Date, to: Date): string {\n  const diff = to.getTime() - from.getTime()\n  const abs = Math.abs(diff)\n  const units: [string, number][] = [['year',365*24*3600*1000],['month',30*24*3600*1000],['day',24*3600*1000],['hour',3600*1000],['minute',60*1000],['second',1000]]\n  for (const [unit, factor] of units) {\n    const n = Math.floor(abs / factor)\n    if (n >= 1) {\n      const label = n === 1 ? unit : unit + 's'\n      return diff >= 0 ? 'in ' + n + ' ' + label : n + ' ' + label + ' ago'\n    }\n  }\n  return 'just now'\n}",
    "tests": [
      {
        "desc": "in 3 days",
        "call": "humanizeRelativeTime(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-04T00:00:00Z\"))",
        "want": "\"in 3 days\""
      },
      {
        "desc": "2 hours ago",
        "call": "humanizeRelativeTime(new Date(\"2024-01-01T02:00:00Z\"),new Date(\"2024-01-01T00:00:00Z\"))",
        "want": "\"2 hours ago\""
      },
      {
        "desc": "1 minute",
        "call": "humanizeRelativeTime(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-01T00:01:00Z\"))",
        "want": "\"in 1 minute\""
      },
      {
        "desc": "1 year",
        "call": "humanizeRelativeTime(new Date(\"2023-01-01T00:00:00Z\"),new Date(\"2024-01-01T00:00:00Z\"))",
        "want": "\"in 1 year\""
      },
      {
        "desc": "just now",
        "call": "humanizeRelativeTime(new Date(\"2024-01-01T00:00:00Z\"),new Date(\"2024-01-01T00:00:00Z\"))",
        "want": "\"just now\""
      }
    ]
  }
]