data: {"type":"layer1","modelId":"local/apple-fm","model":"Crucible (offline)","text":"```typescript\nimport { Zod } from 'zod';\n\nconst ipv4Schema: Zod.Schema<IPv4Address> = {\n  name: {\n    type: 'string',\n    required: true,\n  },\n  address: {\n    type: 'string',\n    required: true,\n    pattern: /^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/,\n  },\n};\n\nexport const validateIpAddress = (data: any): boolean => {\n  return ipv4Schema.parse(data);\n};\n\nexport const ipv4Address: Zod.Schema<IPv4Address> = {\n  ...ipv4Schema,\n};\n```","done":true}

