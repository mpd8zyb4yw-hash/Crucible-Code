data: {"type":"layer1","modelId":"local/apple-fm","model":"Crucible (offline)","text":"```typescript\nimport { EventEmitter } from 'events';\n\nclass SlidingWindowRateLimiter extends EventEmitter {\n  private window: number;\n  private currentWindow: number;\n  private maxRequests: number;\n  private requestCount: number;\n  private keys: Set<string>;\n\n  constructor(maxRequests: number, window: number) {\n    this.maxRequests = maxRequests;\n    this.window = window;\n    this.currentWindow = 0;\n    this.requestCount = 0;\n    this.keys = new Set();\n  }\n\n  tryAcquire(key: string): boolean {\n    if (this.keys.has(key)) {\n      this.currentWindow += 1;\n      if (this.currentWindow > this.window) {\n        this.currentWindow = 0;\n        this.requestCount++;\n      }\n      return false;\n    } else {\n      this.keys.add(key);\n      this.currentWindow = 0;\n      this.requestCount++;\n      return true;\n    }\n  }\n\n  addKey(key: string): void {\n    this.keys.add(key);\n  }\n\n  removeKey(key: string): void {\n    this.keys.delete(key);\n  }\n\n  getCurrentWindow(): number {\n    return this.currentWindow;\n  }\n\n  getRequestCount(): number {\n    return this.requestCount;\n  }\n\n  getKeys(): Set<string> {\n    return this.keys;\n  }\n}\n\n// Test cases\nconst limiter = new SlidingWindowRateLimiter(maxRequests: 3, window: 1000);\n\nconsole.log(limiter.tryAcquire('key1')); // true\nconsole.log(limiter.tryAcquire('key1')); // true\nconsole.log(limiter.tryAcquire('key1')); // true\nconsole.log(limiter.tryAcquire('key1')); // false\nconsole.log(limiter.tryAcquire('key2')); // true\nconsole.log(limiter.tryAcquire('key2')); // true\nconsole.log(limiter.tryAcquire('key2')); // true\nconsole.log(limiter.tryAcquire('key2')); // false\nconsole.log(limiter.tryAcquire('key3')); // true\nconsole.log(limiter.tryAcquire('key3')); // true\nconsole.log(limiter.tryAcquire('key3')); // true\nconsole.log(limiter.tryAcquire('key3')); // false\nconsole.log(limiter.tryAcqui