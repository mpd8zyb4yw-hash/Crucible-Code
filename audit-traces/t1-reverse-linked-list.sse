data: {"type":"layer1","modelId":"local/apple-fm","model":"Crucible (offline)","text":"```typescript\n// Node class for the linked list\nclass Node<T> {\n  data: T;\n  next: Node<T> | null;\n\n  constructor(data: T) {\n    this.data = data;\n    this.next = null;\n  }\n}\n\n// Function to reverse a linked list\nfunction reverseLinkedList(head: Node<T>): Node<T> {\n  let prev: Node<T> | null = null;\n  let current = head;\n\n  while (current !== null) {\n    let nextNode = current.next;\n    current.next = prev;\n    prev = current;\n    current = nextNode;\n  }\n\n  return prev;\n}\n\n// Helper function to create a linked list from an array\nfunction createLinkedList(array: T[]): Node<T> {\n  if (array.length === 0) {\n    return null;\n  }\n\n  let head = new Node<T>(array[0]);\n  let current = head;\n\n  for (let i = 1; i < array.length; i++) {\n    current.next = new Node<T>(array[i]);\n    current = current.next;\n  }\n\n  return head;\n}\n\n// Helper function to convert a linked list to an array\nfunction linkedListToArray(head: Node<T>): T[] {\n  let array: T[] = [];\n  let current = head;\n\n  while (current !== null) {\n    array.push(current.data);\n    current = current.next;\n  }\n\n  return array;\n}\n\n// Test cases\ndescribe(\"Reverse Linked List\", () => {\n  it(\"should reverse a linked list with an even number of nodes\", () => {\n    let head = createLinkedList([1, 2, 3, 4]);\n    let reversedHead = reverseLinkedList(head);\n    expect(linkedListToArray(reversedHead)).toEqual([4, 3, 2, 1]);\n  });\n\n  it(\"should reverse a linked list with an odd number of nodes\", () => {\n    let head = createLinkedList([1, 2, 3]);\n    let reversedHead = reverseLinkedList(head);\n    expect(linkedListToArray(reversedHead)).toEqual([3, 2, 1]);\n  });\n\n  it(\"should reverse an empty linked list\", () => {\n    let head = null;\n    let reversedHead = reverseLinkedList(head);\n    expect(linkedListToArray(reversedHead)).toEqual([]);\n  });\n\n  it(\"should reverse a linked list with a single node\", () => {\n    let head = createLinkedList([1]);\n    let reversedHead = reverseLinkedList(head);\n    expect(linkedListToArray(reversedHead)).toEqual([1]);\n  });\n});\n```","done":true}

