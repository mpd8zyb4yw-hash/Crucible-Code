# Cutover flag for the hosted web build. Copy to `.env.production` ONLY during the
# final off-Fly cutover — AFTER the Worker is deployed and its OAuth secrets are set.
#
# When set, `vite build` (production mode) routes the Continue-with-Google/GitHub
# buttons through the Worker (PROXY_BASE) instead of the old Fly server, so the OAuth
# redirect_uri matches the callback URL registered in the consoles.
#
# Do NOT activate this before the Worker is live, or login on the current site breaks
# in the window before teardown. `vite dev` ignores .env.production, so local dev is
# unaffected either way.
VITE_PROXY_URL=https://proxy.crucible.cam
