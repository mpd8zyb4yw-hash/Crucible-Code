#!/bin/bash
# Crucible.app launcher — opens the app with ZERO terminal interaction.
# Double-click → Electron starts from the source repo and handles everything itself
# (build-if-changed → self-heal → server → window) via electron.cjs in CRUCIBLE_APP_MODE.
# No Terminal window, no manual steps. Logs go to ~/Library/Logs for diagnostics.
REPO="/Users/justin/crucible-local/crucible-local"
LOG="$HOME/Library/Logs/Crucible-launch.log"

cd "$REPO" 2>/dev/null || { osascript -e "display alert \"Crucible\" message \"Repo not found at $REPO\"" 2>/dev/null; exit 1; }

# LaunchServices gives us a bare environment — restore the toolchain PATH.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
export CRUCIBLE_APP_MODE=1

mkdir -p "$HOME/Library/Logs" 2>/dev/null

ELECTRON="$REPO/node_modules/.bin/electron"
if [ -x "$ELECTRON" ]; then
  # `exec` replaces this script with Electron, so the .app process IS the app — no
  # stray shell, no terminal. Output is redirected to the log file.
  exec "$ELECTRON" "$REPO/electron.cjs" >"$LOG" 2>&1
else
  exec npx electron "$REPO/electron.cjs" >"$LOG" 2>&1
fi
